# =============================================================================
# VIGILANCE - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file!
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------

# Server port (default: 3001)
PORT=3001

# Environment (development | production)
NODE_ENV=development

# CORS origin for frontend
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Database (Future - not yet implemented)
# -----------------------------------------------------------------------------

# DATABASE_URL=postgresql://user:password@localhost:5432/vigilance

# -----------------------------------------------------------------------------
# Authentication (Future - not yet implemented)
# -----------------------------------------------------------------------------

# JWT_SECRET=your-super-secret-key-change-in-production
# JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# External APIs (Future - for real sensor integration)
# -----------------------------------------------------------------------------

# SENSOR_API_URL=https://sensors.example.com/api
# SENSOR_API_KEY=your-api-key

# AI Classification API
# ML_API_URL=http://localhost:8000
# ML_API_KEY=your-ml-api-key
